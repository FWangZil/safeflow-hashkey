# LI.FI Composer API Key (get from https://portal.li.fi/)
NEXT_PUBLIC_LIFI_API_KEY=your_api_key_here

# ─── LLM Provider ───────────────────────────────────────────
# Set LLM_PROVIDER to "openai" or "anthropic" (default: openai)
LLM_PROVIDER=openai

# OpenAI-compatible API
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic API
# ANTHROPIC_API_KEY=your_anthropic_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Shared LLM settings
# LLM_MAX_TOKENS=2048
# LLM_TEMPERATURE=0.3

# WalletConnect Project ID (get from https://cloud.walletconnect.com/)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Local Base fork testing (optional)
# Use a dedicated local chain ID such as 31337 to avoid conflicting with the real Base chain in wallet UIs.
# The deploy helper can sync this block automatically with:
# node scripts/deploy-contract-and-configure-web.mjs --network local_base_fork --sync-local-fork-env
# NEXT_PUBLIC_LOCAL_FORK_ENABLED=true
# NEXT_PUBLIC_LOCAL_FORK_CHAIN_ID=31337
# NEXT_PUBLIC_LOCAL_FORK_SOURCE_CHAIN_ID=8453
# NEXT_PUBLIC_LOCAL_FORK_RPC_URL=http://127.0.0.1:8545
# NEXT_PUBLIC_LOCAL_FORK_NAME=Base Fork Local
# NEXT_PUBLIC_LOCAL_FORK_EXPLORER_URL=

# SafeFlow Contract Address (deployed on Base Sepolia)
NEXT_PUBLIC_SAFEFLOW_CONTRACT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SAFEFLOW_CHAIN_ID=84532

# ─── HashKey Mode ──────────────────────────────────────────
# When NEXT_PUBLIC_HASHKEY_ENABLED=true, HashKey chains appear in the wallet picker.
# The UI switches to HashKey mode automatically when the wallet connects to a HashKey chain.
# NEXT_PUBLIC_HASHKEY_ENABLED=true
# NEXT_PUBLIC_HASHKEY_CONTRACT=0x0000000000000000000000000000000000000000
# NEXT_PUBLIC_HASHKEY_CHAIN_ID=133

# ─── HashKey Local Fork (optional) ────────────────────────
# Parallel to the Base local fork — uses a separate anvil instance.
# The deploy helper syncs these automatically:
# ./scripts/start-hashkey-fork.sh
# NEXT_PUBLIC_HASHKEY_LOCAL_FORK_ENABLED=true
# NEXT_PUBLIC_HASHKEY_LOCAL_FORK_CHAIN_ID=31338
# NEXT_PUBLIC_HASHKEY_LOCAL_FORK_RPC_URL=http://127.0.0.1:8546
# NEXT_PUBLIC_HASHKEY_LOCAL_FORK_NAME=HashKey Fork Local
# NEXT_PUBLIC_HASHKEY_LOCAL_FORK_EXPLORER_URL=

# ─── HSP (HashKey Settlement Protocol) ─────────────────────
# Server-side only — do NOT prefix with NEXT_PUBLIC_
# HSP_APP_KEY=your_hsp_app_key
# HSP_APP_SECRET=your_hsp_app_secret
# HSP_MERCHANT_PRIVATE_KEY=your_secp256k1_private_key_hex
# HSP_MERCHANT_NAME=SafeFlow Agent
# HSP_PAY_TO=0x_merchant_receiving_address
# HSP_BASE_URL=https://merchant-qa.hashkeymerchant.com
# HSP_ENVIRONMENT=qa

# ─── Producer API ──────────────────────────────────────────
# HMAC signing secret for intent creation (optional, for external callers)
# PRODUCER_SIGNING_SECRET=your_signing_secret