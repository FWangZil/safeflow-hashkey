# LI.FI Composer API Key (get from https://portal.li.fi/)
NEXT_PUBLIC_LIFI_API_KEY=your_api_key_here

# OpenAI API Key (for AI Strategy Engine)
OPENAI_API_KEY=your_openai_key_here

# WalletConnect Project ID (get from https://cloud.walletconnect.com/)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# SafeFlow Contract Address (deployed on Base Sepolia)
NEXT_PUBLIC_SAFEFLOW_CONTRACT=0x0000000000000000000000000000000000000000
